# 1. Raw Data Storage Component
class DataStorage:
    """Manages the storage of documents using a data access layer"""

    def __init__(self, db, collection_name):
        self.db = db
        self.collection_name = collection_name

    def insert_document(self, document: Dict) -> str:
        """Insert a document and return its ID"""
        result = self.db.insert_one(self.collection_name, document)
        return str(result['inserted_id'])

    def insert_many_documents(self, documents: List[Dict]) -> List[str]:
        """Insert multiple documents and return their IDs"""
        result = self.db.insert_many(self.collection_name, documents)
        return [str(id) for id in result['inserted_ids']]

    def get_document(self, doc_id: str) -> Dict:
        """Retrieve a document by ID"""
        return self.db.find_one(self.collection_name, {'_id': doc_id})

    def get_all_documents(self, limit=None) -> List[Dict]:
        """Retrieve all documents, with an optional limit"""
        return self.db.find(self.collection_name, {}, limit=limit)

    def update_document(self, doc_id: str, document: Dict) -> bool:
        """Update a document"""
        result = self.db.update_one(
            self.collection_name,
            {'_id': doc_id},
            {'$set': document}
        )
        return result['modified_count'] > 0

    def delete_document(self, doc_id: str) -> bool:
        """Delete a document"""
        result = self.db.delete_one(self.collection_name, {'_id': doc_id})
        return result['deleted_count'] > 0

